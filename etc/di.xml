<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="Magento\ReCaptchaValidationApi\Api\ValidatorInterface"
                type="Lohoy\ReCaptchaEnterprise\Model\EnterpriseValidator"/>

    <type name="Magento\ReCaptchaUi\Model\RequestHandler">
        <arguments>
            <argument name="captchaValidator" xsi:type="object">Lohoy\ReCaptchaEnterprise\Model\EnterpriseValidator</argument>
        </arguments>
    </type>

    <virtualType name="LohoyRecaptchaEnterpriseLoggerHandler" type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">var/log/lohoy_recaptcha_enterprise.log</argument>
        </arguments>
    </virtualType>

    <virtualType name="LohoyRecaptchaEnterpriseLogger" type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">recaptcha_enterprise</argument>
            <argument name="handlers" xsi:type="array">
                <item name="default" xsi:type="object">LohoyRecaptchaEnterpriseLoggerHandler</item>
            </argument>
        </arguments>
    </virtualType>

    <type name="Lohoy\ReCaptchaEnterprise\Model\EnterpriseValidator">
        <arguments>
            <argument name="logger" xsi:type="object">LohoyRecaptchaEnterpriseLogger</argument>
        </arguments>
    </type>
</config>
